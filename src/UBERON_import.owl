    <!-- http://purl.obolibrary.org/obo/UBERON_0000161 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000161">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0004111"/>
        <obo:IAO_0000115>Anatomical conduit that connects two adjacent body spaces (or a body space with the space surrounding the organism)[FMA,modified].</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000012>in FMA, this is an anatomical conduit *space*, rather than anatomical conduit</obo:UBPROP_0000012>
