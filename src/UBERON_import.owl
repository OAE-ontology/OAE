    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0000091 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000091">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002050"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000087"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A flattened, almost circular bilaminar plate of cells formed when the inner cell mass (aka embryoblast) forms two epithelial layers, each of a distinct lineage, separated by an extracellular basement membrane: the external (dorsal) layer is called the epiblast and the internal (ventral) layer is called the hypoblast (aka primitive endoderm); together, they compose the bilaminar embryonic disc.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <oboInOwl:hasBroadSynonym>embryonic disc</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>embryonic shield</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>germinal disc</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>germinal disk</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Bilaminar_disc"/>
        <oboInOwl:hasDbXref rdf:resource="http://linkedlifedata.com/resource/umls/id/C1283997"/>
        <oboInOwl:hasDbXref rdf:resource="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C34112"/>
        <oboInOwl:hasDbXref>FMA:293863</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1283997</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>bilaminary embryonic disc</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>bilaminary germ disc</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>bilaminar disk</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0000091</oboInOwl:id>
