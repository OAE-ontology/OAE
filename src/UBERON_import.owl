        <oboInOwl:hasDbXref>VHOG:0001472</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0005064</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>galen:AtrioventricularValve</oboInOwl:hasDbXref>
