        <oboInOwl:hasDbXref>OpenCyc:Mx4rv4EE35wpEbGdrcN5Y29ycA</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0011666</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>pars descendens aortae</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
