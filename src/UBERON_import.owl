    <!-- http://purl.obolibrary.org/obo/UBERON_0000922 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000922">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
