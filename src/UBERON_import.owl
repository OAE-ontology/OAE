    <!-- http://purl.obolibrary.org/obo/UBERON_0001769 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001769">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000481"/>
