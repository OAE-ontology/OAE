                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000320"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>One of the two small elevations on the mucosa of the duodenum, the major at the entrance of the conjoined pancreatic and common bile ducts and the minor at the entrance of the accessory pancreatic duct.</obo:IAO_0000115>
