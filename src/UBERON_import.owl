        <rdfs:label>cloaca</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0000163 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000163">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000162"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002050"/>
