        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
        <rdfs:comment>The lens is avascular and nourished by diffusion from the aqueous and vitreous</rdfs:comment>
        <rdfs:label>lens of camera-type eye</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0000966 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000966">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0004121"/>
