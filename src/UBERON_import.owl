        <oboInOwl:hasExactSynonym>UGE</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>epithelium of urogenital sinus</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0004902</oboInOwl:id>
        <rdfs:label>urogenital sinus epithelium</rdfs:label>
    </owl:Class>
    


