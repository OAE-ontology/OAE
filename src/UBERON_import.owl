    <!-- http://purl.obolibrary.org/obo/UBERON_0002360 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0002360">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000094"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0004121"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0010314"/>
