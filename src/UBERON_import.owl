        <obo:IAO_0000115>One of the three largest glands of the oral cavity that secrete most of the saliva, including the parotid, submandibular, and sublingual glands.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000008>There are 3 pairs of major salivary glands in human and mouse</obo:UBPROP_0000008>
