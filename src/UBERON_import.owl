        <oboInOwl:hasDbXref>XAO:0004143</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>plexus vasculosus</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0005629</oboInOwl:id>
