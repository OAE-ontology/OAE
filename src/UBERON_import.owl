    <!-- http://purl.obolibrary.org/obo/UBERON_0007845 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0007845">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002384"/>
