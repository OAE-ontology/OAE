        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
        <rdfs:label>epiblast (generic)</rdfs:label>
        <foaf:depicted_by rdf:resource="http://upload.wikimedia.org/wikipedia/commons/e/e3/Gray21.png"/>
    </owl:Class>
    


