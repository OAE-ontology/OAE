        <rdfs:seeAlso rdf:resource="https://github.com/obophenotype/uberon/issues/701"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0002049 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0002049">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000477"/>
