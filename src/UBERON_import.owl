        <oboInOwl:hasDbXref>XAO:0000397</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001080</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>sclerotomes</oboInOwl:hasExactSynonym>
