        <oboInOwl:hasDbXref>VHOG:0000288</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001424</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>calvarium</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>neurocranium</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0002241</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
