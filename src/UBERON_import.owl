        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000011>The endodermal cells generate only the lining of the digestive tube and its glands; mesodermal mesenchyme cells will surround this tube to provide the muscles for peristalsis</obo:UBPROP_0000011>
        <oboInOwl:hasDbXref rdf:resource="http://linkedlifedata.com/resource/umls/id/C1514442"/>
        <oboInOwl:hasDbXref rdf:resource="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C34268"/>
