        <oboInOwl:hasDbXref>OpenCyc:Mx4rwNFqppwpEbGdrcN5Y29ycA</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0225776</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0001496</oboInOwl:hasDbXref>
