        <oboInOwl:hasDbXref>UMLS:C0019149</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000220</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>ductus hepaticus communis</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>hepatic duct</oboInOwl:hasRelatedSynonym>
