    <!-- http://purl.obolibrary.org/obo/UBERON_0000086 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000086">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000470"/>
