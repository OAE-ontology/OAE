        <oboInOwl:hasDbXref>MESH:D001646</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0005388</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>galen:Bile</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>fel</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>gall</oboInOwl:hasRelatedSynonym>
