    <!-- http://purl.obolibrary.org/obo/UBERON_0002090 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0002090">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0004120"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0010912"/>
