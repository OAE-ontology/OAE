            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>The fetal urogenital sinus (from which the prostate derives) is a simple cylinder of stratified basal epithelium, surrounded by mesenchyme and positioned between the embryonic bladder and pelvic urethra</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000012>we follow EHDAA2 in dividing the UGS into epithelium and lumen</obo:UBPROP_0000012>
        <oboInOwl:hasDbXref>EHDAA2:0004061</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EMAPA:31509</oboInOwl:hasDbXref>
