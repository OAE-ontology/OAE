    <!-- http://purl.obolibrary.org/obo/UBERON_0001810 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001810">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0003714"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001016"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Anatomical junction where subdivisions of two or more neural trees interconnect with one another to form a network through which nerve fibers of the constituent nerve trees become regrouped; together with other nerve plexuses, nerves and ganglia, it constitutes the peripheral nervous system. Examples: cervical nerve plexus, brachial nerve plexus, sacral nerve plexus[FMA].</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000012>in FMA this is a subtype of junction rather than tissue</obo:UBPROP_0000012>
        <oboInOwl:hasBroadSynonym>plexus</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Nervous_system_plexus"/>
        <oboInOwl:hasDbXref rdf:resource="http://linkedlifedata.com/resource/umls/id/C0501403"/>
