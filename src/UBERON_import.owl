        <oboInOwl:hasExactSynonym>aortic section</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>aortic segment</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>portion of aorta</oboInOwl:hasRelatedSynonym>
