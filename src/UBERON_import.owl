    <!-- http://purl.obolibrary.org/obo/UBERON_0002046 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0002046">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002368"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0004119"/>
