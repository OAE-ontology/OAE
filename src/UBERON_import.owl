    <!-- http://purl.obolibrary.org/obo/UBERON_0005425 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0005425">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UBERON_0006598"/>
