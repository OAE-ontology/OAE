        <oboInOwl:hasDbXref>UMLS:C1514442</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>future digestive tract</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>future digestive tube</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>future gut</oboInOwl:hasExactSynonym>
