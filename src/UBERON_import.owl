    <!-- http://purl.obolibrary.org/obo/UBERON_0011676 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0011676">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000475"/>
        <rdfs:subClassOf>
            <owl:Restriction>
