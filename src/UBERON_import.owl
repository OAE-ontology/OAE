    <!-- http://purl.obolibrary.org/obo/UBERON_0001264 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001264">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002075"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000016"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
