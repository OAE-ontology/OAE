        <oboInOwl:hasDbXref>EMAPA:16832</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:295525</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0231056</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0001198</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>embryonic cloacal membrane</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>membrana cloacalis</oboInOwl:hasRelatedSynonym>
