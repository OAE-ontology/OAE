    <!-- http://purl.obolibrary.org/obo/UBERON_0000081 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000081">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002113"/>
