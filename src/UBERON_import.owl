        <oboInOwl:hasDbXref>EV:0100152</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:86166</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>GAID:933</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MA:0000151</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MAT:0000284</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MESH:D012867</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MIAA:0000284</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>OpenCyc:Mx4rvVjX3ZwpEbGdrcN5Y29ycA</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000860</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>portion of skin</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>region of skin</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>skin</oboInOwl:hasExactSynonym>
