        <oboInOwl:hasDbXref>EMAPA:16672</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:296767</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>TAO:0000122</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1517770</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000166</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0000240</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0000122</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
