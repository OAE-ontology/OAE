        <oboInOwl:hasDbXref>UMLS:C0228603</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000925</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>plexus nervorum spinalium</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>plexus of spinal nerves</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>somatic nerve plexus</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>spinal nerve plexus</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
