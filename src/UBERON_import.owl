        <oboInOwl:hasDbXref>VSAO:0000179</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001383</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>fin bud</oboInOwl:hasExactSynonym>
