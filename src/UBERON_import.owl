    <!-- http://purl.obolibrary.org/obo/UBERON_0001831 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001831">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000409"/>
