                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0005061"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>One of the two elevated edges of the neural groove[GO,MP].</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>In front of the primitive streak two longitudinal ridges, caused by a folding up of the ectoderm, make their appearance, one on either side of the middle line. These are named the neural folds; they commence some little distance behind the anterior end of the embryonic disk, where they are continuous with each other, and from there gradually extend backward, one on either side of the anterior end of the primitive streak. Also, after differentiation it turns into the neural tubes[Wikipedia:Neural_fold].</obo:UBPROP_0000001>
        <oboInOwl:hasDbXref rdf:resource="http://braininfo.rprc.washington.edu/centraldirectory.aspx?ID=1364"/>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Neural_fold"/>
