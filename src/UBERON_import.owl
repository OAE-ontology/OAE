        <oboInOwl:hasDbXref>VHOG:0000484</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0005613</oboInOwl:id>
        <rdfs:label>left dorsal aorta</rdfs:label>
    </owl:Class>
    


