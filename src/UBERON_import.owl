        <oboInOwl:hasDbXref>BTO:0001279</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>CALOHA:TS-0953</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>DHBA:12890</oboInOwl:hasDbXref>
