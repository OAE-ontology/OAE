            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A horn-like keratin structure covering the dorsal aspect of the terminal phalanges of fingers and toes[WP].</obo:IAO_0000115>
        <obo:IAO_0000232>Use this class for both the nails of primates and the homologous claws of mammals such as mouse.</obo:IAO_0000232>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000008>A primate&apos;s nail consists of the unguis alone; the subunguis has disappeared</obo:UBPROP_0000008>
        <dc:contributor rdf:resource="https://github.com/cmungall"/>
        <dc:contributor rdf:resource="https://github.com/mellybelly"/>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Nail_(anatomy)"/>
        <oboInOwl:hasDbXref rdf:resource="http://linkedlifedata.com/resource/umls/id/C0027342"/>
