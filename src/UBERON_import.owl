        <oboInOwl:hasDbXref>EMAPA:36040</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1516779</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>embryo plus adnexa</oboInOwl:hasExactSynonym>
