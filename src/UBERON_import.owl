            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An embryonic structure that is derived from the inner cell mass and lies above the hypoblast and gives rise to the three primary germ layers</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <oboInOwl:hasDbXref rdf:resource="http://linkedlifedata.com/resource/umls/id/C1516906"/>
        <oboInOwl:hasDbXref rdf:resource="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C34164"/>
        <oboInOwl:hasDbXref>EHDAA2:0000444</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EHDAA:42</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EHDAA:75</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EMAPA:16050</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1516906</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>embryonic epiblast</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0008780</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#early_development"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#pheno_slim"/>
        <rdfs:comment>The epiblast cells (appearing on day 8 of human embryonic development) make up a columnar epithelium with dense microvilli on the apical surface. During gastrulation, the epiblast cells undergo epithelial-to-mesenchymal transition and delaminate to become the loose mesenchyme of the primitive streak. The epiblast is present in postimplantation mouse embryos between E5.5-E7.5.</rdfs:comment>
        <rdfs:label>inner cell mass derived epiblast</rdfs:label>
    </owl:Class>
    


