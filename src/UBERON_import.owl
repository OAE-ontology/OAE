        <oboInOwl:hasRelatedSynonym>cerebellar primordium</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>cerebellum primordium</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>dorsal part of alar plate of metencephalon</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>future cerebellum</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>presumptive cerebellum</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>rostral rhombic lip</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0006215</oboInOwl:id>
