    <!-- http://purl.obolibrary.org/obo/UBERON_0004088 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0004088">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001444"/>
