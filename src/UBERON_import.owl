    <!-- http://purl.obolibrary.org/obo/UBERON_0000978 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000978">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0006058"/>
