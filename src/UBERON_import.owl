        <oboInOwl:hasDbXref>ENVO:02000042</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:9673</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>intercellular fluid</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>tissue fluid</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0000913</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#pheno_slim"/>
        <rdfs:label>interstitial fluid</rdfs:label>
    </owl:Class>
    


