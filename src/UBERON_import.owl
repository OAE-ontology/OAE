    <!-- http://purl.obolibrary.org/obo/UBERON_0001705 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001705">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0009564"/>
