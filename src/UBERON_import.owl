    <!-- http://purl.obolibrary.org/obo/UBERON_0004914 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0004914">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0034944"/>
