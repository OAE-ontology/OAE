    <!-- http://purl.obolibrary.org/obo/UBERON_0004086 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0004086">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0003947"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0005358"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0005282"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>one of the system of communicating cavities in the brain that are continuous with the central canal of the spinal cord, that like it are derived from the medullary canal of the embryo, that are lined with an epithelial ependyma, and that contain a serous fluid</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>Organ cavity of the brain which consists of the lateral ventricles, the third and fourth ventricles and the cerebral aqueduct[NIFSTD:birnlex_1356].</obo:UBPROP_0000001>
        <obo:UBPROP_0000012>FMA draws the distinction between e.g. &apos;fourth ventricle&apos; and &apos;cavity of fourth ventricle&apos;. The latter is a cavity, and part of the former, which is a region. The superclass of &apos;fourth ventricle&apos; is_a &apos;region of ventricular system of the brain&apos;. We place this class here, although it is not equivalent to ventricles, as it includes ventricle bodies.</obo:UBPROP_0000012>
        <dc:contributor rdf:resource="https://github.com/cmungall"/>
        <oboInOwl:hasDbXref rdf:resource="http://braininfo.rprc.washington.edu/centraldirectory.aspx?ID=2497"/>
