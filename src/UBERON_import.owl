        <oboInOwl:hasRelatedSynonym>lung interstitium</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>pulmonary connective tissue</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>pulmonary interstitial tissue</oboInOwl:hasRelatedSynonym>
