        <oboInOwl:hasDbXref>TAO:0001202</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0231109</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000167</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001202</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>eye cup</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>eyecup</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ocular cup</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ophtalmic cup</oboInOwl:hasRelatedSynonym>
