    <!-- http://purl.obolibrary.org/obo/UBERON_0001456 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001456">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001444"/>
