        <oboInOwl:hasDbXref>MA:0002507</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MAT:0000444</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MESH:D012463</oboInOwl:hasDbXref>
