    <!-- http://purl.obolibrary.org/obo/UBERON_0001064 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001064">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0007329"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
