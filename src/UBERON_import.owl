    <!-- http://purl.obolibrary.org/obo/UBERON_0009870 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0009870">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0009034"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0034944"/>
