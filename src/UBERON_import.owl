        <oboInOwl:hasDbXref>EMAPA:32725</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:85518</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MA:0000690</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MAT:0000285</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MIAA:0000285</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>OpenCyc:Mx4rvzLD_ZwpEbGdrcN5Y29ycA</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0582802</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000944</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0003032</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>galen:Digit</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>acropodial unit</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>digit (phalangeal portion) plus soft tissue</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>limb digit</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
