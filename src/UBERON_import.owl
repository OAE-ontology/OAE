        <oboInOwl:hasDbXref>VHOG:0001205</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0000453</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001609</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>6th arch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>gill arch 4</oboInOwl:hasExactSynonym>
