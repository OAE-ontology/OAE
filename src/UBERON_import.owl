        <rdfs:comment>Examples include arthropod sensilla.</rdfs:comment>
        <rdfs:label>cell cluster organ</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0010039 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0010039">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0013765"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001555"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0005409"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An organ of the digestive tract that is capable of retaining and storing food</obo:IAO_0000115>
        <obo:IAO_0000232>This is a very broad functionally defined grouping class that collects disparate structures from insects to vertebrates</obo:IAO_0000232>
