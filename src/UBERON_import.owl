        <oboInOwl:hasExactSynonym>second arch pharyngeal pouch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>second visceral pouch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>visceral pouch 2</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>second pharyngeal pouch</oboInOwl:hasRelatedSynonym>
