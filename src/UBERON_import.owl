        <oboInOwl:hasDbXref>UMLS:C0459649</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0000266</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>retina layer</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>retina neuronal layer</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>retinal layer</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>retinal neuronal layer</oboInOwl:hasExactSynonym>
