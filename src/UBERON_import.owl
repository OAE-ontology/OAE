    <!-- http://purl.obolibrary.org/obo/UBERON_0001690 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001690">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000020"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0010314"/>
