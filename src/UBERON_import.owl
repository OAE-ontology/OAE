        <oboInOwl:hasDbXref>UMLS:C0231069</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000561</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000967</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0000247</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001130</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>2nd arch branchial pouch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>2nd arch branchial pouch endoderm</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>2nd arch pouch endoderm</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>2nd branchial pouch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>2nd pharyngeal pouch endoderm</oboInOwl:hasExactSynonym>
