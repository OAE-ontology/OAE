        <rdfs:label>blastula</rdfs:label>
        <foaf:depicted_by rdf:resource="http://upload.wikimedia.org/wikipedia/commons/c/c6/Blastulation.png"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0000310 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000310">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0034929"/>
