    <!-- http://purl.obolibrary.org/obo/UBERON_0003072 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0003072">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000481"/>
