        <oboInOwl:hasDbXref>BAMS:slm</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>neural tube lateral wall sulcus limitans</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0005478</oboInOwl:id>
        <rdfs:label>sulcus limitans of neural tube</rdfs:label>
    </owl:Class>
    


