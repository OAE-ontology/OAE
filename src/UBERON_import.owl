    <!-- http://purl.obolibrary.org/obo/UBERON_0001115 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001115">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001113"/>
        <obo:IAO_0000115>The left lobe is smaller and more flattened than the right. It is situated in the epigastric and left hypochondriac regions. Its upper surface is slightly convex and is moulded on to the diaphragm; its under surface presents the gastric impression and omental tuberosity. [WP,unvetted].</obo:IAO_0000115>
        <obo:IAO_0000116>This class was created automatically from a combination of ontologies</obo:IAO_0000116>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>Portion of the liver which develops on the fish&apos;s left side.[TAO]</obo:UBPROP_0000001>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Left_lobe_of_liver"/>
