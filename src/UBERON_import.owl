    <!-- http://purl.obolibrary.org/obo/UBERON_0001155 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001155">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0004921"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000059"/>
            </owl:Restriction>
        </rdfs:subClassOf>
