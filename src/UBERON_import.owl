        <oboInOwl:hasNarrowSynonym>rectum</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>rectal part of digestive tract</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>terminal section of digestive tract</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0006866</oboInOwl:id>
        <rdfs:label>terminal part of digestive tract</rdfs:label>
    </owl:Class>
    


