        <oboInOwl:hasDbXref>EHDAA:912</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EMAPA:16532</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>TAO:0001435</oboInOwl:hasDbXref>
