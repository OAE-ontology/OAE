    <!-- http://purl.obolibrary.org/obo/UBERON_0003091 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0003091">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000479"/>
