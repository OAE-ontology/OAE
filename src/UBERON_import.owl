        <oboInOwl:hasExactSynonym>pleura visceralis</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>pleura visceralis (pulmonalis)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>pulmonary visceral pleura</oboInOwl:hasExactSynonym>
