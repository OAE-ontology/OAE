    <!-- http://purl.obolibrary.org/obo/UBERON_0000993 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000993">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000025"/>
