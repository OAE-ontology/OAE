        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0000110</oboInOwl:id>
        <rdfs:label>neurula stage</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://github.com/obophenotype/uberon/issues/343"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0000111 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000111">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000067"/>
