        <oboInOwl:hasDbXref rdf:resource="http://linkedlifedata.com/resource/umls/id/C1708242"/>
        <oboInOwl:hasDbXref rdf:resource="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C43370"/>
        <oboInOwl:hasDbXref rdf:resource="http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl#C45715"/>
        <oboInOwl:hasDbXref>BTO:0002991</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0682578</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1708242</oboInOwl:hasDbXref>
