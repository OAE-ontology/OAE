        </rdfs:subClassOf>
        <obo:IAO_0000115>The head is the anterior-most division of the body [GO].</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>Organism subdivision that is the part of the body consisting of the cranial and pharyngeal regions.[AAO]</obo:UBPROP_0000001>
        <obo:UBPROP_0000001>Organism subdivision which is the part of the body which consists of the cranial and pharygeal regions.[TAO]</obo:UBPROP_0000001>
        <obo:UBPROP_0000003>Vertebrate evolution has been characterized by a fresh and vast array of cranial structures that collectively form the head.[well established][VHOG]</obo:UBPROP_0000003>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Head"/>
