        <oboInOwl:hasExactSynonym>cervical nerve</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>cervical nerve tree</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>cervical spinal nerve</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>nervus cervicalis</oboInOwl:hasExactSynonym>
