    <!-- http://purl.obolibrary.org/obo/UBERON_0000015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000466"/>
        <obo:IAO_0000115>A non-material anatomical entity of two dimensions. Anatomical boundaries are contiguous structures.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <oboInOwl:hasDbXref>AEO:0000192</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>CARO:0000010</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:50705</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0000015</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#upper_level"/>
        <rdfs:comment>Except in the case of abstracted fiat boundaries such as the midline plane of an organism, all 2D anatomical entities have a 3 dimensional projection. For example, the surface of the shell of a muscle has a distinct shape that projects into the third dimension. Note that boundaries are 2D structures. They have no thickness - and so can not be sites of gene expression or gene product localisation. For this, use boundary region terms.</rdfs:comment>
        <rdfs:label>anatomical boundary</rdfs:label>
    </owl:Class>
    


