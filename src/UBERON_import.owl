        <obo:IAO_0000115>A gland in which the principal secretory cells are mucus secreting cells.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000008>In frogs and salamanders, this is the smaller of the two types of gland, the other being the granular (poison) gland. In these species the mucous gland is a cluster of cells that release secretion into a common duct[Kardong]</obo:UBPROP_0000008>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Mucous_gland"/>
        <oboInOwl:hasDbXref>AAO:0010601</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>BTO:0001979</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:62888</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>glandula mucosa</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>muciparous gland</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>mucous secreting gland</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>mucus gland</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>mucus-secreting gland</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0000414</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#organ_slim"/>
        <rdfs:label>mucous gland</rdfs:label>
        <foaf:depicted_by rdf:resource="http://upload.wikimedia.org/wikipedia/commons/c/c0/Gray1021.png"/>
    </owl:Class>
    


