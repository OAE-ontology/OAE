    <!-- http://purl.obolibrary.org/obo/UBERON_0001282 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001282">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0003704"/>
