        <oboInOwl:hasDbXref>TAO:0001440</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0004135</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001440</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
