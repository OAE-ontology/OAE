        <oboInOwl:hasDbXref>RETIRED_EHDAA2:0003197</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0003066</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>hind limb bud</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>posterior limb bud</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>leg bud</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>limb bud - hindlimb</oboInOwl:hasRelatedSynonym>
