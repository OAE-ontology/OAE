    <!-- http://purl.obolibrary.org/obo/UBERON_0005162 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0005162">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000477"/>
        <obo:IAO_0000115>A structure consisting of multiple cell components but which is not itself a cell and does not have (complete) cells as a part.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000012>we go with the FMA classification rather than the CARO one. FMA def: &apos;Anatomical cluster which has as direct parts cell parts from two or more cells.&apos;</obo:UBPROP_0000012>
        <oboInOwl:hasDbXref>AAO:0011000</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>CARO:0001000</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FBbt:00007060</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:83115</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>multi-cell-component structure</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>multi-cell-part structure</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>cell part cluster</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0005162</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#upper_level"/>
        <rdfs:label>multi cell part structure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0005171 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0005171">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002394"/>
