        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0034922"/>
        <obo:IAO_0000115>A small cluster of cells of various types which form a discrete structure, largely delimited by a morphological boundary and whose components work together to make the whole structure capable of a specific function.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
