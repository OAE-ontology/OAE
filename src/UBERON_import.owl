                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0010743"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A structure found in the walls of the ventricles of the brain, consisting of part of the meninges (pia mater in mammals) plus ependyma[cjm].</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>Portion of tissue that is part of the primitive meninx which forms a fold, roofing a ventricle of the brain and supporting the choroid plexus[ZFA:0000447].</obo:UBPROP_0000001>
        <obo:UBPROP_0000010>Vascularized tela choroidea is choroid plexus.</obo:UBPROP_0000010>
        <obo:UBPROP_0000012>Note that the structure in ZFA may be different</obo:UBPROP_0000012>
        <oboInOwl:hasDbXref rdf:resource="http://braininfo.rprc.washington.edu/centraldirectory.aspx?ID=1378"/>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Tela_chorioidea"/>
        <oboInOwl:hasDbXref>FMA:242849</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>TAO:0000447</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0000447</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>tela chorioidea</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0005283</oboInOwl:id>
