        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#uberon_slim"/>
        <rdfs:comment>The mouse parotid, exorbital lacrimal gland and exocrine pancreas have similar histological appearances[ISBN10:0123813611]</rdfs:comment>
        <rdfs:label>parotid gland</rdfs:label>
