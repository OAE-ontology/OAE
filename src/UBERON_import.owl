    <!-- http://purl.obolibrary.org/obo/UBERON_0004237 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0004237">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
