        <oboInOwl:hasDbXref>MESH:A16.254.462</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0282505</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0003161</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>limb buds</oboInOwl:hasExactSynonym>
