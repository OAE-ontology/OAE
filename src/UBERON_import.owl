    <!-- http://purl.obolibrary.org/obo/UBERON_0001829 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001829">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001044"/>
