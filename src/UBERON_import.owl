        <oboInOwl:hasDbXref>EFO:0001980</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EMAPA:16775</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EV:0100044</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:9583</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>GAID:360</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MA:0000433</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MESH:D010994</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>OpenCyc:Mx4rv3zwLZwpEbGdrcN5Y29ycA</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0032225</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000394</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>wall of pleural sac</oboInOwl:hasExactSynonym>
