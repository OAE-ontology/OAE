            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A limb bud that develops into a hindlimb.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>The bilateral thickening of the ectoderm in the region of the first noticeable at NF stage 47, and innervated by NF stage 51. The hind limb buds develop before the forelimb buds.[AAO]</obo:UBPROP_0000001>
        <oboInOwl:hasDbXref rdf:resource="http://www.snomedbrowser.com/Codes/Details/346164003"/>
        <oboInOwl:hasDbXref>AAO:0010382</oboInOwl:hasDbXref>
