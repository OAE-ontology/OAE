        <oboInOwl:hasDbXref>EHDAA:264</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EMAPA:16101</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1518429</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0001212</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0006267</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#emapa_ehdaa2"/>
        <rdfs:label>notochordal plate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0006268 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0006268">
