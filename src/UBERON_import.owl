        <obo:IAO_0000115>The layer of undifferentiated, proliferating cells that line the neural tube lumen that is the immediate transformation of the germinal neuroepithelium</obo:IAO_0000115>
        <obo:IAO_0000116>consider merging with &apos;ventricular zone&apos;; note that the MA class probably does not belong here, as this is an embryonic structure</obo:IAO_0000116>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>The layer of undifferentiated, proliferating cells that line the neural tube lumen</obo:UBPROP_0000001>
        <oboInOwl:hasBroadSynonym>ependymal layer</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref>EMAPA:17152</oboInOwl:hasDbXref>
