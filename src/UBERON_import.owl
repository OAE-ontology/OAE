    <!-- http://purl.obolibrary.org/obo/UBERON_0001464 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001464">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000475"/>
