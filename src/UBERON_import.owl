        <oboInOwl:id>UBERON:0004347</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#pheno_slim"/>
        <rdfs:comment>developmentally_induced_by Fgf10, capable of initiating limb forming interactions between endoderm and mesoderm</rdfs:comment>
        <rdfs:label>limb bud</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0004348 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0004348">
