    <!-- http://purl.obolibrary.org/obo/UBERON_0002114 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0002114">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0004921"/>
