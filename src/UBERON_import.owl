        <obo:IAO_0000115>A collection of two or more connected limb segments. Examples: arm (comprising stylopod and zeugopod regions).</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
