    <!-- http://purl.obolibrary.org/obo/UBERON_0002185 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0002185">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000117"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0007196"/>
            </owl:Restriction>
        </rdfs:subClassOf>
