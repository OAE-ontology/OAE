        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000003>A study of embryos shows that in all vertebrates six arterial arches link the ventral aorta with a pair of lateral dorsal aortae on each side of the body. The latter unite posteriorly to form a single median dorsal aorta wich takes blood to the body.[well established][VHOG]</obo:UBPROP_0000003>
        <obo:UBPROP_0000008>Contributes to the arch of aorta in humans</obo:UBPROP_0000008>
        <oboInOwl:hasDbXref rdf:resource="http://www.snomedbrowser.com/Codes/Details/361403005"/>
