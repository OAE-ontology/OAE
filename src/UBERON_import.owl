        <oboInOwl:hasDbXref>ZFA:0005173</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>liver right lobe</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>lobus hepaticus dexter</oboInOwl:hasExactSynonym>
