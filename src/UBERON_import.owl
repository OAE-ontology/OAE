        <oboInOwl:hasDbXref>BILA:0000010</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>CARO:0001002</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EHDAA2:0003192</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:24137</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ID:0000000</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1515977</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0005594</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0006984</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#upper_level"/>
        <rdfs:comment>Old definition: &apos;Non-material anatomical entity of two dimensions, that is demarcated by anatomical lines or points on the external or internal surfaces of anatomical structures.&apos; Note, in the new definition, the space referred to is not necessarily an anatomical space. It may be the outside of an organism.</rdfs:comment>
        <rdfs:label>anatomical surface</rdfs:label>
    </owl:Class>
    


