    <!-- http://purl.obolibrary.org/obo/UBERON_0009955 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0009955">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002546"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_2007013"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002385"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001714"/>
            </owl:Restriction>
