        <obo:IAO_0000115>Cardiac chamber through which blood leaves the heart.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>A chamber of the heart that receives blood from one or more atria and pumps it by muscular contraction into the arteries.[AAO]</obo:UBPROP_0000001>
        <obo:UBPROP_0000001>One of four heart chambers.[TAO]</obo:UBPROP_0000001>
        <obo:UBPROP_0000003>In the primitive vertebrate heart the four chambers are: 1. Sinus venosus (...) 2. Atrium (...) 3. Ventricle (...) 4. Conus arteriosus (...)[well established][VHOG]</obo:UBPROP_0000003>
        <oboInOwl:hasBroadSynonym>ventricle</oboInOwl:hasBroadSynonym>
