        <rdfs:label>mucus</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0000913 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000913">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000463"/>
        <obo:IAO_0000115>Interstitial fluid is a bodily fluid consisting of a solution which bathes and surrounds the cells of multicellular animals. It is the main component of the extracellular fluid, which also includes plasma and transcellular fluid.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <oboInOwl:hasDbXref rdf:resource="http://en.wikipedia.org/wiki/Interstitial_fluid"/>
