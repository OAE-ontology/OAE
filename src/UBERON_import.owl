    <!-- http://purl.obolibrary.org/obo/UBERON_0004117 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0004117">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0003258"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0004814"/>
