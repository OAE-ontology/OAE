    <!-- http://purl.obolibrary.org/obo/UBERON_0000105 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000105">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
