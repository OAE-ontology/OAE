        <obo:IAO_0000115>the tubular structure that conducts gall bladder contents from the gall bladder to the common bile duct</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
