    <!-- http://purl.obolibrary.org/obo/UBERON_0001737 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001737">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000072"/>
