    <!-- http://purl.obolibrary.org/obo/UBERON_0000916 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000916">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0009569"/>
