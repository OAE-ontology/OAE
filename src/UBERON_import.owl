        <oboInOwl:hasDbXref>galen:Cecum</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>caecum</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>cecum</oboInOwl:hasExactSynonym>
