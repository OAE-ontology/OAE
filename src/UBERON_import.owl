        <oboInOwl:hasRelatedSynonym>lingual swelling</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0006260</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#emapa_ehdaa2"/>
        <rdfs:comment>the collection consisting of the two lateral swellings and the medial swelling</rdfs:comment>
        <rdfs:label>lingual swellings</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/UBERON_0006267 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0006267">
