        <oboInOwl:hasDbXref>EMAPA:16118</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:293019</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MFMO:0000095</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>TAO:0001595</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1517197</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000296</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0000097</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001612</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>1st pharyngeal arch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>branchial arch 1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>first branchial arch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>first pharyngeal arch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>first visceral arch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>mandibular arch</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>visceral arch 1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>1st arch</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>1st visceral arch</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>arcus pharyngeus primus</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0004362</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#pheno_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#uberon_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
        <rdfs:label>pharyngeal arch 1</rdfs:label>
        <foaf:depicted_by rdf:resource="http://upload.wikimedia.org/wikipedia/commons/2/2d/Gray48.png"/>
