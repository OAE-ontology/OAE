            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Outermost layer of cells surrounding the embryo.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/uberon.owl"/>
        <obo:UBPROP_0000001>Outermost monolayer of cells surrounding the embryo that become very flattened in the blastula and give rise to the periderm. Sometimes used synonymously with periderm. Kimmel et al, 1995.[TAO]</obo:UBPROP_0000001>
        <obo:UBPROP_0000002>relationship loss: develops_from superficial blastomere (TAO:0001484)[TAO]</obo:UBPROP_0000002>
        <obo:UBPROP_0000008>Originally this tissue is one cell layer thick but in most vertebrates it soon becomes a two layered structure. The outer layer gives rise to the periderm.</obo:UBPROP_0000008>
        <oboInOwl:hasDbXref>EFO:0003425</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>TAO:0000086</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0000086</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>EVL</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>enveloping layer</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>UBERON:0007383</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#efo_slim"/>
        <rdfs:label>enveloping layer of ectoderm</rdfs:label>
    </owl:Class>
    


