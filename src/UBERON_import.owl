        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>coelem</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>coelomic cavity</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0011997</oboInOwl:id>
