    <!-- http://purl.obolibrary.org/obo/UBERON_0000414 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000414">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002365"/>
