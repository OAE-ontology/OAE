        <oboInOwl:hasDbXref>ZFA:0001260</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>endocrine pancreas</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>pars endocrina pancreatis</oboInOwl:hasExactSynonym>
