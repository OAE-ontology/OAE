        <oboInOwl:hasDbXref>ENVO:02000023</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:62971</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>GAID:1157</oboInOwl:hasDbXref>
