        <obo:OAE_0001849>椎体脱位</obo:OAE_0001849>
        <obo:OAE_0001849>腰椎脱位</obo:OAE_0001849>
        <obo:OAE_0004334>10013183</obo:OAE_0004334>
        <rdfs:label>obsolete dislocation of vertebra AE</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007811 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007811">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which refers to any clinical syndrome with either an excess of movement or a paucity of voluntary and involuntary movements, unrelated to weakness or spasticity.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
        <obo:IAO_0000119>http://en.volupedia.org/wiki/Movement_disorder</obo:IAO_0000119>
        <obo:IAO_0100001 rdf:resource="http://purl.obolibrary.org/obo/OAE_0002787"/>
        <obo:OAE_0001849>锥体外系疾病</obo:OAE_0001849>
        <obo:OAE_0004334>10015832</obo:OAE_0004334>
        <rdfs:label>obsolete extrapyramidal disorder AE</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007862 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007862">
