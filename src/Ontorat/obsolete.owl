        <obo:OAE_0001849>纤维化腱</obo:OAE_0001849>
        <obo:OAE_0004334>10016662</obo:OAE_0004334>
        <rdfs:label>obsolete fibrosis tendinous AE</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007716 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007716">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is the region of the upper limb between the elbow and the wrist which is fracture.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
        <obo:IAO_0000119>http://en.volupedia.org/wiki/Forearm#Fracture</obo:IAO_0000119>
