    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0006620 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0006620">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is the invasion of an organism&apos;s body tissues by disease-causing agents, their multiplication, and the reaction of host tissues to the infectious agents and the toxins they produce such as hepatic infection.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
