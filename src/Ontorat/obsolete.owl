    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0008001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0008001">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is any of various types of abnormal growth or development of cells (microscopic scale) or organs (macroscopic scale), and the abnormal histology or anatomical structure resulting from such growth.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
        <obo:IAO_0000119>http://en.volupedia.org/wiki/Dysplasia</obo:IAO_0000119>
        <obo:IAO_0100001 rdf:resource="http://purl.obolibrary.org/obo/OAE_0003245"/>
