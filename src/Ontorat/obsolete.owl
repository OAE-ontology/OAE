    <!-- http://purl.obolibrary.org/obo/OAE_0007459 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007459">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is a condition in which the adrenal glands do not produce adequate amounts of steroid hormones, primarily cortisol; but may also include impaired production of aldosterone (a mineralocorticoid), which regulates sodium conservation, potassium secretion, and water retention.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
        <obo:IAO_0000119>http://en.volupedia.org/wiki/Adrenal_insufficiency</obo:IAO_0000119>
        <obo:IAO_0100001 rdf:resource="http://purl.obolibrary.org/obo/OAE_0000266"/>
        <obo:OAE_0001849>肾上腺抑制</obo:OAE_0001849>
        <obo:OAE_0004334>10001382</obo:OAE_0004334>
        <rdfs:label>obsolete adrenal suppression AE</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007506 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007506">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is a medical condition involving the death of tubular epithelial cells that form the renal tubules of the kidneys.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
        <obo:IAO_0000119>http://en.volupedia.org/wiki/Acute_tubular_necrosis</obo:IAO_0000119>
