    <!-- http://purl.obolibrary.org/obo/OAE_0007684 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007684">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is a medical condition characterized by chronic widespread pain and a heightened pain response to pressure.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
        <obo:IAO_0000119>http://en.volupedia.org/wiki/Fibromyalgia</obo:IAO_0000119>
