        <obo:OAE_0004334>10016997</obo:OAE_0004334>
        <rdfs:label>obsolete forearm fracture AE</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007744 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007744">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is a bone fracture caused by weakness of the bone structure that leads to decrease mechanical resistance to normal mechanical loads.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
