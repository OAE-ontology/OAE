        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007782 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007782">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is a disease of the muscle  in which the muscle fibers do not function properly.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
