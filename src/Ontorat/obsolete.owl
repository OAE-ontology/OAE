        <obo:OAE_0004334>10038540</obo:OAE_0004334>
        <rdfs:label>obsolete renal tubular necrosis AE</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007631 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007631">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is the result of a process reducing hydrogen ion concentration of arterial blood plasma (alkalemia).</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
        <obo:IAO_0000119>http://en.volupedia.org/wiki/Alkalosis</obo:IAO_0000119>
