        <obo:IAO_0100001 rdf:resource="http://purl.obolibrary.org/obo/OAE_0004238"/>
        <obo:OAE_0001849>肌筋膜炎</obo:OAE_0001849>
        <obo:OAE_0004334>10052443</obo:OAE_0004334>
        <rdfs:label>obsolete myofascitis AE</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007810 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007810">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is a dislocation of an irregular bone with a complex structure composed of bone and some hyaline cartilage, the proportions of which vary according to the segment of the backbone and the species of vertebrate.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
        <obo:IAO_0000119>http://en.volupedia.org/wiki/Vertebra</obo:IAO_0000119>
