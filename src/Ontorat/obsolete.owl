    <!-- http://purl.obolibrary.org/obo/OAE_0007687 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007687">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which is a pathological wound healing in which connective tissue replaces normal tendinous parenchymal tissue to the extent that it goes unchecked, leading to considerable tissue remodelling and the formation of permanent scar tissue.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
