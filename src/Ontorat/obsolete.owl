        <rdfs:label>obsolete myopathy AE</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OAE_0007790 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OAE_0007790">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0000115>This is an AE which main cause of the disease is aseptic inflammation of local muscles and connective tissues such as myofascial, which can be manifested as paralysis, distension, and other discomfort, local muscle stiffness, spasm or palpable strain-like nodules.</obo:IAO_0000115>
        <obo:IAO_0000117>QY, JX, HY</obo:IAO_0000117>
